# ============================================
# Конфигурация для сайта-визитки + RAG-ассистента
# ============================================

# --------------------------------------------
# ОБЯЗАТЕЛЬНО: API ключ ProxyAPI
# Используется для сайта, RAG и Telegram бота
# Получить: https://proxyapi.ru
# --------------------------------------------
PROXY_API_KEY=your-proxy-api-key-here

# Альтернативно: прямой ключ OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# --------------------------------------------
# Telegram бот (для RAG-ассистента)
# Получить токен: @BotFather в Telegram
# --------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --------------------------------------------
# Настройки моделей RAG
# --------------------------------------------

# Модель для генерации ответов (gpt-3.5-turbo, gpt-4, gpt-4-turbo)
MODEL_NAME=gpt-3.5-turbo

# Температура (0.0 - точно, 1.0 - креативно)
TEMPERATURE=0.7

# Модель эмбеддингов (text-embedding-3-small, text-embedding-3-large)
EMBEDDING_MODEL=text-embedding-3-small

# --------------------------------------------
# Настройки векторной базы RAG
# --------------------------------------------
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=rag_documents

# --------------------------------------------
# Настройки кеша и логов RAG
# --------------------------------------------
CACHE_FILE=cache.json
LOGS_DB_PATH=logs.db

# --------------------------------------------
# Общие настройки
# --------------------------------------------
DEBUG=true
LOG_LEVEL=info
